# Postgres connection string
#   Local dev (docker compose up -d): postgres://cleansource:cleansource@localhost:5433/cleansource
#   Production (Neon):                postgres://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgres://cleansource:cleansource@localhost:5433/cleansource

# Long random string used to sign tokens/cookies (openssl rand -base64 32)
BETTER_AUTH_SECRET=replace-with-a-long-random-string

# Public URL of the API server (used by Better Auth for callbacks/cookies)
BETTER_AUTH_URL=http://localhost:4000

# Comma-separated origins allowed to call the API with credentials
CORS_ORIGIN=http://localhost:3000
