{
  "expo": {
    "name": "CleanSource",
    "slug": "cleansource",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cleansource",
    "userInterfaceStyle": "light",
    "primaryColor": "#0e3b7b",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "sa.cleansource.app"
    },
    "android": {
      "package": "sa.cleansource.app",
      "adaptiveIcon": {
        "backgroundColor": "#0e3b7b",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "locales": {
      "ar": "./src/locales/native/ar.json",
      "en": "./src/locales/native/en.json"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0e3b7b",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#0e3b7b"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "CleanSource uses your location to pin your pickup address."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "supportsRTL": true
    }
  }
}
