// CleanSource Laundry — domain schema.
// Money is stored in halalas (integer minor units of SAR).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums (mirrors @cleansource/contracts) ─────────────────────────────

enum OrderType {
  BY_WEIGHT
  BY_ITEM
}

enum OrderStatus {
  PLACED
  PICKED_UP
  IN_PROGRESS
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  MADA
  STC_PAY
  APPLE_PAY
  GOOGLE_PAY
  CARD
  CASH_ON_PICKUP
  WALLET
}

enum AddressLabel {
  HOME
  WORK
  OTHER
}

enum ServiceCode {
  WASH_AND_FOLD
  DRY_CLEAN
  IRONING
  CARPET
}

enum SubscriptionFrequency {
  WEEKLY
  BI_WEEKLY
}

enum Language {
  ar
  en
}

// ─── Identity ───────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  fullName  String?
  email     String?
  language  Language @default(ar)
  /// Expo push token of the user's current device (order-status notifications).
  pushToken String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses     Address[]
  orders        Order[]
  wallet        Wallet?
  notifications Notification[]
  tickets       SupportTicket[]
  subscription  Subscription?
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, consumed])
}

// ─── Addresses ──────────────────────────────────────────────────────────

model Address {
  id          String       @id @default(cuid())
  userId      String
  label       AddressLabel
  street      String
  building    String?
  apartment   String?
  driverNotes String?
  latitude    Float?
  longitude   Float?
  isDefault   Boolean      @default(false)
  createdAt   DateTime     @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
}

// ─── Catalog ────────────────────────────────────────────────────────────

model Service {
  id        String      @id @default(cuid())
  code      ServiceCode @unique
  nameAr    String
  nameEn    String
  descAr    String
  descEn    String
  isActive  Boolean     @default(true)
  sortOrder Int         @default(0)

  items ServiceItem[]
}

model ServiceItem {
  id        String  @id @default(cuid())
  serviceId String
  nameAr    String
  nameEn    String
  /// halalas per piece
  price     Int
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  service    Service     @relation(fields: [serviceId], references: [id])
  orderItems OrderItem[]

  @@index([serviceId])
}

model WeightPackage {
  id       String  @id @default(cuid())
  kg       Int
  nameAr   String
  nameEn   String
  descAr   String
  descEn   String
  /// halalas
  price    Int
  isActive Boolean @default(true)

  orders Order[]
}

model PromoCode {
  id            String    @id @default(cuid())
  code          String    @unique
  /// e.g. 20 = 20% off
  percentOff    Int
  /// halalas — cap on the discount; null = no cap
  maxDiscount   Int?
  firstOrderOnly Boolean  @default(false)
  expiresAt     DateTime?
  isActive      Boolean   @default(true)

  orders Order[]
}

// ─── Orders ─────────────────────────────────────────────────────────────

model Order {
  id                  String        @id @default(cuid())
  reference           String        @unique
  userId              String
  type                OrderType
  status              OrderStatus   @default(PLACED)
  addressId           String
  pickupDate          DateTime      @db.Date
  pickupSlot          String // e.g. "09-11"
  paymentMethod       PaymentMethod
  specialInstructions String?

  // Price breakdown (halalas)
  subtotal         Int
  discount         Int @default(0)
  walletCreditUsed Int @default(0)
  vat              Int
  total            Int

  weightPackageId String?
  promoCodeId     String?
  driverId        String?
  cancelReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  address       Address        @relation(fields: [addressId], references: [id])
  weightPackage WeightPackage? @relation(fields: [weightPackageId], references: [id])
  promoCode     PromoCode?     @relation(fields: [promoCodeId], references: [id])
  driver        Driver?        @relation(fields: [driverId], references: [id])
  items         OrderItem[]
  rating        Rating?
  statusEvents  OrderStatusEvent[]

  @@index([userId, status])
}

model OrderItem {
  id            String @id @default(cuid())
  orderId       String
  serviceItemId String
  quantity      Int
  /// halalas — unit price captured at order time
  unitPrice     Int

  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  serviceItem ServiceItem @relation(fields: [serviceItemId], references: [id])

  @@index([orderId])
}

/// Timeline events powering live tracking (placed → … → delivered).
model OrderStatusEvent {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Driver {
  id       String  @id @default(cuid())
  name     String
  phone    String
  rating   Float   @default(5)
  isActive Boolean @default(true)

  orders Order[]
}

model Rating {
  id          String   @id @default(cuid())
  orderId     String   @unique
  stars       Int
  compliments String[]
  comment     String?
  createdAt   DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ─── Wallet ─────────────────────────────────────────────────────────────

model Wallet {
  id      String @id @default(cuid())
  userId  String @unique
  /// halalas
  balance Int    @default(0)

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id        String   @id @default(cuid())
  walletId  String
  /// halalas — positive = credit, negative = debit
  amount    Int
  reason    String // e.g. REFUND, ORDER_PAYMENT, REFERRAL_BONUS
  orderId   String?
  createdAt DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
}

// ─── Engagement ─────────────────────────────────────────────────────────

model Subscription {
  id         String                @id @default(cuid())
  userId     String                @unique
  frequency  SubscriptionFrequency
  kgPerCycle Int
  /// halalas per month
  price      Int
  isPaused   Boolean               @default(false)
  renewsAt   DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  titleAr   String
  titleEn   String
  bodyAr    String
  bodyEn    String
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model SupportTicket {
  id          String   @id @default(cuid())
  reference   String   @unique
  userId      String
  orderId     String?
  problemType String // MISSING_ITEM, DAMAGE, LATE, QUALITY
  description String
  status      String   @default("UNDER_REVIEW")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
